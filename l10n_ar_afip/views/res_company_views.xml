<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista para agregar campos AFIP heredando de la vista base -->
    <record id="view_company_form_afip" model="ir.ui.view">
        <field name="name">res.company.form.afip</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[last()]" position="after">
                <page name="afip" string="AFIP">
                    <group>
                        <group string="Datos AFIP">
                            <field name="afip_cuit" placeholder="CUIT"/>
                            <field name="afip_ws_environment"/>
                            <field name="afip_point_of_sale"/>
                        </group>
                        <group string="Certificado">
                            <button name="action_generate_csr" string="Generar Clave y CSR" type="object" class="btn-secondary" colspan="2"/>
                            <field name="afip_csr" readonly="1" widget="ace" options="{'mode': 'text'}" placeholder="Genere el CSR primero"/>
                            <button name="action_download_csr" string="Descargar CSR" type="object" class="btn-secondary"/>
                            <button name="action_copy_private_key" string="Ver/Copiar Clave Privada" type="object" class="btn-secondary"/>
                            <field name="afip_certificate" widget="binary" string="Certificado (archivo)"/>
                            <field name="afip_certificate_text" widget="ace" options="{'mode': 'text'}" string="Certificado (pegar texto PEM)" placeholder="-----BEGIN CERTIFICATE-----"/>
                            <field name="afip_private_key_text" widget="ace" options="{'mode': 'text'}" string="Clave Privada (pegar texto PEM)" placeholder="-----BEGIN PRIVATE KEY-----"/>
                        </group>
                        <group string="WSAA">
                            <field name="afip_token" readonly="1"/>
                            <field name="afip_sign" readonly="1"/>
                            <field name="afip_token_expiration" readonly="1"/>
                            <button name="refresh_afip_token" string="Refrescar Token" type="object" class="btn-secondary" colspan="2"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
