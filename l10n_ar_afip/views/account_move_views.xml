<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Account Move Form View -->
    <record id="view_move_form_afip" model="ir.ui.view">
        <field name="name">account.move.form.afip</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_post']" position="after">
                <button name="action_request_afip_cae" string="Solicitar CAE" type="object" 
                        invisible="state != 'posted' or cae != False or move_type not in ['out_invoice', 'out_refund']"
                        class="btn-primary"/>
                <button name="action_retry_afip_cae" string="Reintentar CAE" type="object"
                        invisible="state != 'posted' or cae != False or afip_result != 'R' or move_type not in ['out_invoice', 'out_refund']"
                        class="btn-warning"/>
            </xpath>
            <xpath expr="//page[@name='other_info']" position="after">
                <page name="afip" string="AFIP" invisible="move_type not in ['out_invoice', 'out_refund']">
                    <group>
                        <group string="CAE" invisible="not cae">
                            <field name="cae" readonly="1"/>
                            <field name="cae_due_date" readonly="1"/>
                        </group>
                        <group string="CAE" invisible="cae">
                            <div class="alert alert-warning">
                                Esta factura aún no tiene CAE. Haga clic en "Solicitar CAE" para autorizarla con AFIP.
                            </div>
                        </group>
                        <group string="Resultado AFIP">
                            <field name="l10n_ar_afip_state" readonly="1"/>
                            <field name="afip_result" readonly="1"/>
                            <field name="afip_document_type" readonly="1"/>
                            <field name="afip_document_number" readonly="1"/>
                            <field name="afip_barcode" readonly="1" invisible="not afip_barcode"/>
                        </group>
                        <group string="Errores" invisible="not afip_errors">
                            <field name="afip_errors" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="not cae">
                        <div class="col-12 border bg-light p-3 text-center">
                            <img t-if="afip_barcode" t-att-src="'/report/barcode/Code128/%s' % afip_barcode" height="50"/>
                        </div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Account Journal Form View -->
    <record id="view_account_journal_form_afip" model="ir.ui.view">
        <field name="name">account.journal.form.afip</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="l10n_ar_afip_pto_vta" invisible="type not in ['sale', 'purchase']"/>
                <field name="l10n_ar_afip_document_type" invisible="type not in ['sale', 'purchase']"/>
                <field name="l10n_ar_afip_auto_authorize" invisible="type not in ['sale']"/>
            </xpath>
        </field>
    </record>
</odoo>
