<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_afip" model="ir.ui.view">
        <field name="name">account.move.form.afip</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other_info']" position="after">
                <page name="afip" string="AFIP">
                    <group>
                        <group string="CAE">
                            <field name="cae"/>
                            <field name="cae_due_date"/>
                        </group>
                        <group string="Resultado AFIP">
                            <field name="l10n_ar_afip_state"/>
                            <field name="afip_result"/>
                            <field name="afip_document_type"/>
                            <field name="afip_document_number"/>
                            <button name="action_request_afip_cae" string="Solicitar CAE" type="object"/>
                            <button name="action_retry_afip_cae" string="Reintentar CAE" type="object"/>
                        </group>
                        <group string="Errores">
                            <field name="afip_errors"/>
                        </group>
                    </group>
                    <group string="Código QR">
                        <field name="afip_qr_image" widget="image" readonly="1" class="oe_avatar" style="max-width: 75px; max-height: 75px;" options='{"size": [75, 75], "width": 75, "height": 75, "zoom": false}'/>
                        <button name="regenerate_afip_qr" string="Regenerar QR" type="object" invisible="not cae"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_account_journal_form_afip" model="ir.ui.view">
        <field name="name">account.journal.form.afip</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="l10n_ar_afip_pto_vta"/>
                <field name="l10n_ar_afip_document_type"/>
                <field name="l10n_ar_afip_auto_authorize"/>
            </xpath>
        </field>
    </record>
</odoo>
