<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <report id="l10n_ar_afip.report_invoice"
            string="Factura ARCA"
            model="account.move"
            report_type="qweb-pdf"
            name="l10n_ar_afip.report_invoice_afip"
            file="l10n_ar_afip/report_invoice_afip"
            print_report_name="'Factura_ARCA_%s' % (object.name or 'draft').replace('/', '_')"
            paperformat="paperformat_afip"
    />

    <record id="paperformat_afip" model="report.paperformat">
        <field name="name">Paperformat AFIP Argentina</field>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line">False</field>
        <field name="header_spacing">10</field>
    </record>
</odoo>
