<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_afip_v2">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-family: Arial, Helvetica, sans-serif; font-size: 8px; color: #222; background: #efefef; border: 1px solid #777; border-radius: 8px; padding: 10px 12px; min-height: 272mm; box-sizing: border-box; position: relative; padding-bottom: 34mm;">
                    <t t-set="doc_letter" t-value="o.afip_document_type if o.afip_document_type in ['A', 'B', 'C'] else 'A'"/>
                    <t t-set="doc_title" t-value="'FACTURAS %s' % doc_letter"/>
                    <t t-set="doc_code" t-value="{'A': 1, 'B': 6, 'C': 11}.get(doc_letter, 1)"/>
                    <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: not l.display_type)"/>
                    <t t-set="company_cuit" t-value="o.company_id.afip_cuit or o.company_id.vat or '-'"/>

                    <div style="border: 1px solid #666; border-radius: 8px; overflow: hidden; margin-bottom: 8px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 28%; padding: 8px 10px; vertical-align: middle; background: #f3f3f3;">
                                    <t t-if="o.company_id.logo">
                                        <img t-att-src="image_data_uri(o.company_id.logo)" style="max-width: 86px; max-height: 40px;"/>
                                    </t>
                                    <t t-else="">
                                        <div style="font-size: 16px; font-weight: 700;"><span t-field="o.company_id.name"/></div>
                                    </t>
                                </td>
                                <td style="width: 15%; text-align: center; vertical-align: middle; font-size: 12px;">Comprobante<br/>electronico</td>
                                <td style="width: 14%; text-align: center; background: #e6e6e6; border-left: 1px solid #d5d5d5; border-right: 1px solid #d5d5d5;">
                                    <div style="font-size: 58px; line-height: 0.86; margin-top: -4px;"><span t-esc="doc_letter"/></div>
                                    <div style="font-size: 31px; line-height: 1; margin-top: -2px;">cod. <span t-esc="doc_code"/></div>
                                </td>
                                <td style="width: 43%; padding: 6px 10px; vertical-align: top;">
                                    <div style="font-size: 39px; font-weight: 700; line-height: 0.96;"><span t-esc="doc_title"/></div>
                                    <div style="font-size: 27px; margin-top: 2px;">Fecha: <span t-field="o.invoice_date"/></div>
                                    <div style="font-size: 35px; line-height: 1; margin-top: 2px;"><span t-field="o.name"/></div>
                                    <div style="font-size: 13px; margin-top: 2px;">Tipo de Documento <span t-esc="doc_title"/></div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div style="border: 1px solid #666; border-radius: 8px; padding: 5px 10px; margin-bottom: 8px; font-size: 33px; line-height: 1;">Fecha Vto: <span t-field="o.invoice_date_due"/></div>

                    <div style="border: 1px solid #666; border-radius: 8px; padding: 10px; margin-bottom: 8px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 51%; vertical-align: top; font-size: 34px; line-height: 1.25;">
                                    <div style="font-weight: 700;"><span t-field="o.company_id.name"/></div>
                                    <div><span t-field="o.company_id.name"/></div>
                                    <div><span t-field="o.company_id.street"/></div>
                                    <div>
                                        <t t-if="o.company_id.city"><span t-field="o.company_id.city"/></t>
                                        <t t-if="o.company_id.state_id"> <span t-field="o.company_id.state_id"/></t>
                                        <t t-if="o.company_id.zip"> <span t-field="o.company_id.zip"/></t>
                                    </div>
                                    <div><t t-if="o.company_id.country_id"><span t-field="o.company_id.country_id"/></t></div>
                                </td>
                                <td style="width: 49%; vertical-align: top; font-size: 37px; line-height: 1.22; padding-top: 2px;">
                                    <div><strong>CUIT</strong> <span t-esc="company_cuit"/> - <t t-if="o.company_id.l10n_ar_afip_responsibility_type_id"><span t-field="o.company_id.l10n_ar_afip_responsibility_type_id"/></t><t t-else="">IVA Responsable Inscripto</t></div>
                                    <div style="margin-top: 9px;"><strong>Ingresos Brutos:</strong> <t t-if="o.company_id.l10n_ar_afip_iibb"><span t-field="o.company_id.l10n_ar_afip_iibb"/></t><t t-else="">-</t></div>
                                    <div><strong>Inicio de actividades:</strong> <t t-if="o.company_id.l10n_ar_afip_start_date"><span t-field="o.company_id.l10n_ar_afip_start_date"/></t><t t-else="">-</t></div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div style="border: 1px solid #666; border-radius: 8px; padding: 8px 10px; margin-bottom: 12px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 17%; font-size: 35px; font-weight: 700; vertical-align: top;">Cliente</td>
                                <td style="width: 34%; font-size: 37px; line-height: 1.2; vertical-align: top;">
                                    <div><span t-field="o.partner_id"/></div>
                                    <div><span t-field="o.partner_id.street"/></div>
                                    <div>
                                        <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                        <t t-if="o.partner_id.state_id"> <span t-field="o.partner_id.state_id"/></t>
                                        <t t-if="o.partner_id.zip"> <span t-field="o.partner_id.zip"/></t>
                                    </div>
                                    <div><t t-if="o.partner_id.country_id"><span t-field="o.partner_id.country_id"/></t></div>
                                </td>
                                <td style="width: 49%; font-size: 37px; line-height: 1.2; vertical-align: top;">
                                    <div><strong>CUIT:</strong> <span t-field="o.partner_id.vat"/></div>
                                    <div style="margin-top: 9px;"><strong>Condicion de IVA</strong> <t t-if="o.partner_id.l10n_ar_afip_responsibility_type_id"><span t-field="o.partner_id.l10n_ar_afip_responsibility_type_id"/></t><t t-else="">IVA Responsable Inscripto</t></div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div style="font-size: 35px; font-weight: 700;">Moneda:</div>
                    <div style="font-size: 41px; margin-top: 1px; margin-bottom: 10px;"><span t-esc="o.currency_id.name"/></div>

                    <table style="width: 100%; border-collapse: collapse; font-size: 31px; margin-bottom: 2px;">
                        <thead>
                            <tr style="border-top: 1px solid #c8ccd2; border-bottom: 1px solid #c8ccd2;">
                                <th style="text-align: left; padding: 4px 10px 4px 10px; width: 9%;">Codigo</th>
                                <th style="text-align: left; padding: 4px 10px 4px 6px; width: 22%;">Descripcion</th>
                                <th style="text-align: left; padding: 4px 6px; width: 18%;">Documento Origen</th>
                                <th style="text-align: right; padding: 4px 6px; width: 10%;">Cantidad</th>
                                <th style="text-align: right; padding: 4px 6px; width: 13%;">Precio Unitario</th>
                                <th style="text-align: right; padding: 4px 6px; width: 9%;">Desc.(%)</th>
                                <th style="text-align: right; padding: 4px 6px; width: 10%;">Alicuota IVA</th>
                                <th style="text-align: right; padding: 4px 10px 4px 6px; width: 9%;">Monto Final</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="product_lines" t-as="line">
                                <tr>
                                    <td style="padding: 10px 10px 4px 10px;"><span t-field="line.product_id.default_code"/></td>
                                    <td style="padding: 10px 10px 4px 6px;"><span t-field="line.name"/></td>
                                    <td style="padding: 10px 6px 4px 6px;">-</td>
                                    <td style="padding: 10px 6px 4px 6px; text-align: right;"><span t-field="line.quantity"/></td>
                                    <td style="padding: 10px 6px 4px 6px; text-align: right;"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    <td style="padding: 10px 6px 4px 6px; text-align: right;"><span t-field="line.discount"/></td>
                                    <td style="padding: 10px 6px 4px 6px; text-align: right;"><t t-foreach="line.tax_ids" t-as="tax"><span t-esc="'IVA %s%%' % int(tax.amount)"/></t></td>
                                    <td style="padding: 10px 10px 4px 6px; text-align: right;"><span t-field="line.price_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <table style="width: 100%; border-collapse: collapse; font-size: 39px; margin-top: 22px;">
                        <tr>
                            <td style="width: 68%; vertical-align: top; font-size: 36px;">Plazo de pago: <span t-field="o.invoice_payment_term_id"/></td>
                            <td style="width: 32%; vertical-align: top;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr style="border-top: 1px solid #5b5b5b;">
                                        <td style="padding: 9px 2px; font-weight: 700;">Subtotal</td>
                                        <td style="padding: 9px 2px; text-align: right;"><span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    </tr>
                                    <tr style="border-top: 1px solid #c8ccd2;">
                                        <td style="padding: 10px 2px 7px 2px; font-weight: 700;">Impuesto</td>
                                        <td style="padding: 10px 2px 7px 2px; text-align: right; font-weight: 700;">Base&#160;&#160;&#160;Monto</td>
                                    </tr>
                                    <tr style="border-top: 1px solid #c8ccd2;">
                                        <td style="padding: 8px 2px;">IVA 21%</td>
                                        <td style="padding: 8px 2px; text-align: right;"><span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>&#160;&#160;<span t-field="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    </tr>
                                    <tr style="border-top: 1px solid #5b5b5b;">
                                        <td style="padding: 12px 2px; font-size: 47px; font-weight: 700;">Total</td>
                                        <td style="padding: 12px 2px; text-align: right; font-size: 47px;"><span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <div style="position: absolute; left: 12px; right: 12px; bottom: 10px; border: 1px solid #5f5f5f; padding: 8px 10px 3px 10px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 34%; vertical-align: top; font-size: 35px; line-height: 1.2;">
                                    <div><strong>CAE:</strong> <span t-field="o.cae"/></div>
                                    <div style="margin-top: 12px;"><strong>Fecha Vencimiento CAE:</strong> <span t-field="o.cae_due_date"/></div>
                                </td>
                                <td style="width: 18%; vertical-align: top; text-align: center; font-size: 35px; font-weight: 700;">Codigo de Barras:</td>
                                <td style="width: 48%; vertical-align: top; text-align: center;">
                                    <t t-if="o.afip_barcode">
                                        <div t-field="o.afip_barcode" t-options="{'widget': 'barcode', 'symbology': 'Code128', 'img_style': 'width:330px;height:52px;'}" style="margin-top: 2px;"/>
                                        <div style="font-size: 31px; margin-top: 2px;"><span t-field="o.afip_barcode"/></div>
                                    </t>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
