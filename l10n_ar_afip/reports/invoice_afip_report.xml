<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_afip">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-family: Helvetica, Arial, sans-serif; font-size: 11px; padding: 20px;">
                    
                    <!-- Encabezado completo -->
                    <table style="width: 100%; margin-bottom: 15px; border-bottom: 3px double #000;">
                        <tr>
                            <!-- Datos Emisor -->
                            <td style="width: 55%; vertical-align: top; padding-right: 20px;">
                                <strong style="font-size: 18px; color: #333;">
                                    <t t-if="o.company_id.name"><span t-field="o.company_id.name"/></t>
                                </strong><br/>
                                <span t-field="o.company_id.street"/>
                                <t t-if="o.company_id.street2">, <span t-field="o.company_id.street2"/></t><br/>
                                <t t-if="o.company_id.city"><span t-field="o.company_id.city"/></t>
                                <t t-if="o.company_id.state_id">, <span t-field="o.company_id.state_id"/></t>
                                <t t-if="o.company_id.zip"> (CP: <span t-field="o.company_id.zip"/>)</t><br/>
                                <t t-if="o.company_id.phone">Tel: <span t-field="o.company_id.phone"/><br/></t>
                                <t t-if="o.company_id.email">Email: <span t-field="o.company_id.email"/></t>
                            </td>
                            
                            <!-- Renglón A - Factura -->
                            <td style="width: 45%; text-align: right; vertical-align: top;">
                                <div style="border: 3px double #000; padding: 15px; display: inline-block; width: 280px;">
                                    <div style="text-align: center; border-bottom: 1px solid #000; padding-bottom: 8px; margin-bottom: 8px;">
                                        <strong style="font-size: 22px;">FACTURA</strong>
                                        <t t-if="o.afip_document_type == 'A'"><br/><span>Factura A</span></t>
                                        <t t-if="o.afip_document_type == 'B'"><br/><span>Factura B</span></t>
                                        <t t-if="o.afip_document_type == 'C'"><br/><span>Factura C</span></t>
                                    </div>
                                    <table style="width: 100%;">
                                        <tr>
                                            <td style="text-align: left;"><strong>Punto de Venta:</strong></td>
                                            <td style="text-align: right;"><span t-esc="(o.journal_id.l10n_ar_afip_pto_vta or 1)"/></td>
                                        </tr>
                                        <tr>
                                            <td style="text-align: left;"><strong>Comprobante N°:</strong></td>
                                            <td style="text-align: right;"><span t-esc="o.name.split('/')[-1] if '/' in o.name else o.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="text-align: left;"><strong>Fecha:</strong></td>
                                            <td style="text-align: right;"><span t-field="o.invoice_date"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <!-- CUIT y datos AFIP -->
                    <div style="background-color: #f5f5f5; border: 1px solid #999; padding: 10px; margin-bottom: 15px;">
                        <table style="width: 100%;">
                            <tr>
                                <td style="width: 33%;">
                                    <strong>CUIT:</strong> <span t-field="o.company_id.afip_cuit"/>
                                </td>
                                <td style="width: 33%;">
                                    <strong>Ing. Brutos:</strong> <t t-if="o.company_id.l10n_ar_afip_iibb"><span t-field="o.company_id.l10n_ar_afip_iibb"/></t><t t-else="">-</t>
                                </td>
                                <td style="width: 34%;">
                                    <strong>Inicio Act.:</strong> <t t-if="o.company_id.l10n_ar_afip_start_date"><span t-field="o.company_id.l10n_ar_afip_start_date"/></t><t t-else="">-</t>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <!-- Datos del Receptor -->
                    <div style="border: 1px solid #000; padding: 10px; margin-bottom: 15px;">
                        <strong>PERÍODO FISCAL:</strong> <span>...........</span><br/>
                        <strong>Denominación:</strong> <span t-field="o.partner_id"/><br/>
                        <strong>Domicilio:</strong> 
                        <span t-field="o.partner_id.street"/>
                        <t t-if="o.partner_id.city">, <span t-field="o.partner_id.city"/></t>
                        <t t-if="o.partner_id.state_id">, <span t-field="o.partner_id.state_id"/></t>
                        <br/>
                        <table style="width: 100%;">
                            <tr>
                                <td style="width: 25%;">
                                    <strong>CUIT:</strong> <span t-field="o.partner_id.vat"/>
                                </td>
                                <td style="width: 25%;">
                                    <strong>Cond. IVA:</strong>
                                    <t t-if="o.partner_id.l10n_ar_afip_responsibility_type_id">
                                        <span t-field="o.partner_id.l10n_ar_afip_responsibility_type_id"/>
                                    </t>
                                    <t t-else="">Consumidor Final</t>
                                </td>
                                <td style="width: 25%;">
                                    <strong>Cond. Pago:</strong> <span t-field="o.invoice_payment_term_id"/>
                                </td>
                                <td style="width: 25%;">
                                    <strong>Vto.:</strong> <span t-field="o.invoice_date_due"/>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <!-- Tabla de Items -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px;">
                        <thead>
                            <tr style="background-color: #333; color: white;">
                                <th style="padding: 8px; border: 1px solid #000; text-align: center; width: 8%;">Código</th>
                                <th style="padding: 8px; border: 1px solid #000; text-align: left; width: 35%;">Descripción</th>
                                <th style="padding: 8px; border: 1px solid #000; text-align: center; width: 8%;">Cantidad</th>
                                <th style="padding: 8px; border: 1px solid #000; text-align: center; width: 8%;">U. Medida</th>
                                <th style="padding: 8px; border: 1px solid #000; text-align: right; width: 13%;">Precio Unit.</th>
                                <th style="padding: 8px; border: 1px solid #000; text-align: center; width: 8%;">IVA</th>
                                <th style="padding: 8px; border: 1px solid #000; text-align: right; width: 20%;">Importe</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.invoice_line_ids" t-as="line">
                                <tr>
                                    <td style="padding: 6px; border: 1px solid #000; text-align: center;">
                                        <span t-field="line.product_id.default_code"/>
                                    </td>
                                    <td style="padding: 6px; border: 1px solid #000;">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td style="padding: 6px; border: 1px solid #000; text-align: center;">
                                        <span t-field="line.quantity"/>
                                    </td>
                                    <td style="padding: 6px; border: 1px solid #000; text-align: center;">UN</td>
                                    <td style="padding: 6px; border: 1px solid #000; text-align: right;">
                                        <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                    <td style="padding: 6px; border: 1px solid #000; text-align: center;">
                                        <t t-foreach="line.tax_ids" t-as="tax">
                                            <span t-esc="int(tax.amount)"/>%
                                        </t>
                                    </td>
                                    <td style="padding: 6px; border: 1px solid #000; text-align: right;">
                                        <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                            </t>
                            <!-- Filas vacías para completar -->
                            <t t-set="empty_rows" t-value="max(0, 8 - len(o.invoice_line_ids))"/>
                            <t t-foreach="range(empty_rows)" t-as="i">
                                <tr style="height: 25px;">
                                    <td style="padding: 6px; border: 1px solid #000;">&#160;</td>
                                    <td style="padding: 6px; border: 1px solid #000;">&#160;</td>
                                    <td style="padding: 6px; border: 1px solid #000;">&#160;</td>
                                    <td style="padding: 6px; border: 1px solid #000;">&#160;</td>
                                    <td style="padding: 6px; border: 1px solid #000;">&#160;</td>
                                    <td style="padding: 6px; border: 1px solid #000;">&#160;</td>
                                    <td style="padding: 6px; border: 1px solid #000;">&#160;</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Totales -->
                    <table style="width: 100%; margin-bottom: 15px;">
                        <tr>
                            <td style="width: 60%;">
                                <!-- Espacio para leyenda IVA -->
                            </td>
                            <td style="width: 40%;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr>
                                        <td style="padding: 6px; border: 1px solid #000; text-align: right; background-color: #f5f5f5; width: 60%;">
                                            <strong>Subtotal:</strong>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #000; text-align: right; width: 40%;">
                                            <span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px; border: 1px solid #000; text-align: right; background-color: #f5f5f5;">
                                            <strong>IVA:</strong>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #000; text-align: right;">
                                            <span t-field="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr style="background-color: #333; color: white;">
                                        <td style="padding: 10px; border: 2px solid #000; text-align: right;">
                                            <strong style="font-size: 14px;">TOTAL:</strong>
                                        </td>
                                        <td style="padding: 10px; border: 2px solid #000; text-align: right;">
                                            <strong style="font-size: 16px;">
                                                <span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </strong>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- CAE Section -->
                    <t t-if="o.cae">
                        <table style="width: 100%; border: 2px solid #000; margin-top: 20px;">
                            <tr>
                                <td style="padding: 15px; width: 70%; vertical-align: middle;">
                                    <table style="width: 100%;">
                                        <tr>
                                            <td colspan="2" style="padding-bottom: 10px;">
                                                <strong>CAI / CAE:</strong> <span style="font-size: 16px; font-weight: bold;" t-field="o.cae"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding-bottom: 5px;">
                                                <strong>Fecha Vto. CAE:</strong> <span t-field="o.cae_due_date"/>
                                            </td>
                                            <td>
                                                <span style="color: green; font-weight: bold; font-size: 14px;">✓ DOCUMENTO VÁLIDO</span>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="padding: 15px; text-align: center; border-left: 2px solid #000; width: 30%;">
                                    <img t-if="o.afip_qr_image" t-attf-src="data:image/png;base64,{{ o.afip_qr_image }}" style="width: 90px; height: 90px;"/>
                                </td>
                            </tr>
                        </table>
                    </t>

                    <!-- Observaciones -->
                    <t t-if="o.narration">
                        <div style="margin-top: 20px; padding: 10px; border: 1px solid #999;">
                            <strong>Observaciones:</strong><br/>
                            <span t-field="o.narration"/>
                        </div>
                    </t>

                    <!-- Footer -->
                    <div style="margin-top: 30px; padding-top: 10px; border-top: 1px solid #999; text-align: center; font-size: 9px; color: #666;">
                        <p>Documento emitido de acuerdo a la Resolución General AFIP N° 1415 y modificatorias | Sistema: AgroSentinel ERP</p>
                    </div>

                </div>
            </t>
        </t>
    </template>
</odoo>
