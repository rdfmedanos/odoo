<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_afip_v2">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #1f1f1f; background: #ffffff; padding: 8mm; min-height: 270mm; box-sizing: border-box; position: relative; padding-bottom: 42mm;">
                    <t t-set="doc_letter" t-value="o.afip_document_type if o.afip_document_type in ['A', 'B', 'C'] else 'A'"/>
                    <t t-set="doc_title" t-value="'FACTURAS %s' % doc_letter"/>
                    <t t-set="doc_code" t-value="{'A': 1, 'B': 6, 'C': 11}.get(doc_letter, 1)"/>
                    <t t-set="product_lines" t-value="o._l10n_ar_afip_report_lines()"/>
                    <t t-set="company_cuit" t-value="o.company_id.afip_cuit or o.company_id.vat or '-'"/>
                    <t t-set="company_iibb" t-value="o.company_id.l10n_ar_afip_iibb or company_cuit"/>

                    <div style="border: 1px solid #666; border-radius: 7px; overflow: hidden; margin-bottom: 6px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                            <td style="width: 28%; padding: 6px 8px; vertical-align: middle; background: #ffffff;">
                                    <t t-if="o.company_id.logo"><img t-att-src="image_data_uri(o.company_id.logo)" style="max-width: 90px; max-height: 42px;"/></t>
                                    <t t-else=""><strong><span t-field="o.company_id.name"/></strong></t>
                                </td>
                                <td style="width: 14%; text-align: center; vertical-align: middle; font-size: 7pt;">
                                    <div style="display: flex; align-items: center; justify-content: center; min-height: 44px; line-height: 1.1;">Comprobante<br/>electronico</div>
                                </td>
                                <td style="width: 16%; text-align: center; vertical-align: middle; background: #ffffff; border-left: 1px solid #d1d1d1; border-right: 1px solid #d1d1d1;">
                                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 44px;">
                                        <div style="font-size: 28pt; line-height: 1;"><span t-esc="doc_letter"/></div>
                                        <div style="font-size: 11pt; line-height: 1.1;">cod. <span t-esc="doc_code"/></div>
                                    </div>
                                </td>
                                <td style="width: 42%; padding: 5px 8px; vertical-align: top;">
                                    <div style="margin-left: 20%;">
                                        <div style="font-size: 16pt; font-weight: 700; line-height: 1;"><span t-esc="doc_title"/></div>
                                        <div style="font-size: 10pt; margin-top: 3px;">Fecha: <span t-field="o.invoice_date"/></div>
                                        <div style="font-size: 12pt; line-height: 1.1;"><span t-field="o.name"/></div>
                                        <div style="font-size: 6pt; margin-top: 2px;">Tipo de Documento <span t-esc="doc_title"/></div>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div style="border: 1px solid #666; border-radius: 7px; padding: 2px 8px; margin-bottom: 6px; font-size: 11pt;">Fecha Vto: <span t-field="o.invoice_date_due"/></div>

                    <div style="border: 1px solid #666; border-radius: 7px; padding: 7px 8px; margin-bottom: 6px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 50%; vertical-align: top; font-size: 10pt; line-height: 1.4;">
                                    <div style="font-weight: 700;"><span t-field="o.company_id.name"/></div>
                                    <div><span t-field="o.company_id.name"/></div>
                                    <div><span t-field="o.company_id.street"/></div>
                                    <div>
                                        <t t-if="o.company_id.city"><span t-field="o.company_id.city"/></t>
                                        <t t-if="o.company_id.state_id"> <span t-field="o.company_id.state_id"/></t>
                                        <t t-if="o.company_id.zip"> <span t-field="o.company_id.zip"/></t>
                                    </div>
                                    <div><t t-if="o.company_id.country_id"><span t-field="o.company_id.country_id"/></t></div>
                                </td>
                                <td style="width: 50%; vertical-align: top; font-size: 10pt; line-height: 1.4;">
                                    <div><strong>CUIT</strong> <span t-esc="company_cuit"/> - <t t-if="o.company_id.l10n_ar_afip_responsibility_type_id"><span t-field="o.company_id.l10n_ar_afip_responsibility_type_id"/></t><t t-else="">IVA Responsable Inscripto</t></div>
                                    <div style="margin-top: 5px;"><strong>Ingresos Brutos:</strong> <span t-esc="company_iibb"/></div>
                                    <div><strong>Inicio de actividades:</strong> <t t-if="o.company_id.l10n_ar_afip_start_date"><span t-field="o.company_id.l10n_ar_afip_start_date"/></t><t t-else="">-</t></div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div style="border: 1px solid #666; border-radius: 7px; padding: 7px 8px; margin-bottom: 9px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 17%; font-size: 10pt; font-weight: 700; vertical-align: top;">Cliente</td>
                                <td style="width: 33%; font-size: 10pt; line-height: 1.35; vertical-align: top;">
                                    <div><span t-field="o.partner_id"/></div>
                                    <div><span t-field="o.partner_id.street"/></div>
                                    <div>
                                        <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                        <t t-if="o.partner_id.state_id"> <span t-field="o.partner_id.state_id"/></t>
                                        <t t-if="o.partner_id.zip"> <span t-field="o.partner_id.zip"/></t>
                                    </div>
                                    <div><t t-if="o.partner_id.country_id"><span t-field="o.partner_id.country_id"/></t></div>
                                </td>
                                <td style="width: 50%; font-size: 10pt; line-height: 1.35; vertical-align: top;">
                                    <div><strong>CUIT:</strong> <span t-field="o.partner_id.vat"/></div>
                                    <div style="margin-top: 5px;"><strong>Condicion de IVA</strong> <t t-if="o.partner_id.l10n_ar_afip_responsibility_type_id"><span t-field="o.partner_id.l10n_ar_afip_responsibility_type_id"/></t><t t-else="">IVA Responsable Inscripto</t></div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div style="font-size: 10pt; font-weight: 700;">Moneda:</div>
                    <div style="font-size: 11pt; margin-top: 1px; margin-bottom: 8px;"><span t-esc="o.currency_id.name"/></div>

                    <table style="width: 100%; border-collapse: collapse; font-size: 9pt; margin-bottom: 6px;">
                        <thead>
                            <tr style="border-top: 1px solid #c8ccd2; border-bottom: 1px solid #c8ccd2;">
                                <th style="text-align: left; padding: 4px 8px; width: 10%;">Codigo</th>
                                <th style="text-align: left; padding: 4px 6px; width: 24%;">Descripcion</th>
                                <th style="text-align: left; padding: 4px 6px; width: 17%;">Documento Origen</th>
                                <th style="text-align: right; padding: 4px 6px; width: 10%;">Cantidad</th>
                                <th style="text-align: right; padding: 4px 6px; width: 13%;">Precio Unitario</th>
                                <th style="text-align: right; padding: 4px 6px; width: 8%;">Desc.(%)</th>
                                <th style="text-align: right; padding: 4px 6px; width: 9%;">Alicuota IVA</th>
                                <th style="text-align: right; padding: 4px 8px 4px 6px; width: 9%;">Monto Final</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="product_lines" t-as="line">
                                <tr>
                                    <td style="padding: 7px 8px 2px 8px;"><span t-field="line.product_id.default_code"/></td>
                                    <td style="padding: 7px 6px 2px 6px;"><span t-field="line.name"/></td>
                                    <td style="padding: 7px 6px 2px 6px;">-</td>
                                    <td style="padding: 7px 6px 2px 6px; text-align: right;"><span t-field="line.quantity"/></td>
                                    <td style="padding: 7px 6px 2px 6px; text-align: right;"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    <td style="padding: 7px 6px 2px 6px; text-align: right;"><span t-field="line.discount"/></td>
                                    <td style="padding: 7px 6px 2px 6px; text-align: right;"><t t-foreach="line.tax_ids" t-as="tax"><span t-esc="'IVA ' + str(int(tax.amount)) + '%'"/></t></td>
                                    <td style="padding: 7px 8px 2px 6px; text-align: right;"><span t-field="line.price_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                            </t>
                            <tr t-if="not product_lines">
                                <td colspan="8" style="padding: 8px; color: #666; font-style: italic;">Sin lineas de producto visibles en la factura.</td>
                            </tr>
                        </tbody>
                    </table>

                    <table style="width: 100%; border-collapse: collapse; font-size: 10pt; margin-top: 10mm;">
                        <tr>
                            <td style="width: 68%; vertical-align: top;">Plazo de pago: <span t-field="o.invoice_payment_term_id"/></td>
                            <td style="width: 32%; vertical-align: top;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr style="border-top: 1px solid #5b5b5b;">
                                        <td style="padding: 7px 2px; font-weight: 700;">Subtotal</td>
                                        <td style="padding: 7px 2px; text-align: right;"><span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    </tr>
                                    <tr style="border-top: 1px solid #c8ccd2;">
                                        <td style="padding: 7px 2px 5px 2px; font-weight: 700;">Impuesto</td>
                                        <td style="padding: 7px 2px 5px 2px; text-align: right; font-weight: 700;">Base&#160;&#160;Monto</td>
                                    </tr>
                                    <tr style="border-top: 1px solid #c8ccd2;">
                                        <td style="padding: 6px 2px;">IVA 21%</td>
                                        <td style="padding: 6px 2px; text-align: right;"><span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>&#160;&#160;<span t-field="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    </tr>
                                    <tr style="border-top: 1px solid #5b5b5b;">
                                        <td style="padding: 9px 2px; font-size: 15pt; font-weight: 700;">Total</td>
                                        <td style="padding: 9px 2px; text-align: right; font-size: 15pt;"><span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <div style="position: absolute; left: 8mm; right: 8mm; bottom: -75mm; border: 1px solid #5f5f5f; padding: 8px 8px 4px 8px; min-height: 24mm; background: #ffffff;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 28%; vertical-align: top; text-align: left; padding-left: 0;">
                                    <t t-if="o.afip_qr_image">
                                        <img t-attf-src="data:image/png;base64,{{ o.afip_qr_image }}" style="width: 130px; height: 130px; display: block; margin: 0;"/>
                                    </t>
                                    <div style="font-size: 8pt; font-weight: 700; margin-top: 3px; width: 130px; text-align: center;">Codigo QR ARCA</div>
                                </td>
                                <td style="width: 44%; vertical-align: top; font-size: 8pt; line-height: 1.25; padding: 0 2px 2px 0; text-align: left;">
                                    <div style="margin-left: -93px;">
                                        <img src="https://neofactura.com.ar/uploads/logo-arca.jpg" style="width: 98px; height: auto; display: block; margin-top: 16px; margin-bottom: 16px;"/>
                                        <div style="font-weight: 700; margin-bottom: 2px;">Comprobante Autorizado</div>
                                        <div>Comprobante electronico autorizado por AFIP. Esta Administracion Federal no se responsabiliza por los datos ingresados en el detalle de la operacion.</div>
                                    </div>
                                </td>
                                <td style="width: 28%; vertical-align: top; text-align: right; font-size: 10pt; line-height: 1.25;">
                                    <div><strong>CAE:</strong> <span t-field="o.cae"/></div>
                                    <div style="margin-top: 7px; white-space: nowrap;"><strong>Fecha Vencimiento CAE:</strong> <span t-field="o.cae_due_date"/></div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
