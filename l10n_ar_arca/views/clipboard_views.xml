<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista para copiar al portapapeles -->
    <record id="view_l10n_ar_afip_clipboard" model="ir.ui.view">
        <field name="name">l10n.ar.afip.clipboard.form</field>
        <field name="model">l10n_ar_afip.clipboard</field>
        <field name="arch" type="xml">
            <form string="Clave Privada">
                <sheet>
                    <p>Copie la clave privada a continuación (Ctrl+A, Ctrl+C):</p>
                    <field name="key_content" widget="ace" options="{'mode': 'text', 'showInvisibleCharacters': true}" readonly="1" style="height: 200px; background-color: #f5f5f5;"/>
                </sheet>
                <footer>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para el clipboard -->
    <record id="action_l10n_ar_afip_clipboard" model="ir.actions.act_window">
        <field name="name">Clave Privada - Copiar</field>
        <field name="res_model">l10n_ar_afip.clipboard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
