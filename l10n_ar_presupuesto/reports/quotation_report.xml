<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_sale_order_arca">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
                    <div class="page presupuesto-doc" style="font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #1f1f1f; background: #ffffff; padding: 8mm 6.4mm; min-height: 270mm; box-sizing: border-box; position: relative;">
                            <t t-set="doc_color" t-value="o.company_id.primary_color or '#8d97a5'"/>
                            <style>
                                .presupuesto-doc .card {
                                    border: 2px solid #8d97a5 !important;
                                    border-radius: 10px;
                                    overflow: hidden;
                                    background: #fff;
                                    box-shadow: none !important;
                                }
                                .presupuesto-doc,
                                .presupuesto-doc * {
                                    box-shadow: none !important;
                                    outline: none !important;
                                }
                                .presupuesto-doc table,
                                .presupuesto-doc tr,
                                .presupuesto-doc th,
                                .presupuesto-doc td {
                                    border: none !important;
                                    border-color: transparent !important;
                                }
                                .presupuesto-doc td.doc-type-box {
                                    box-shadow: inset 2px 0 0 #8d97a5, inset -2px 0 0 #8d97a5 !important;
                                }
                                .presupuesto-doc .soft-sep {
                                    border-top: none !important;
                                }
                                .presupuesto-doc .totals-row,
                                .presupuesto-doc .totals-row td {
                                    border: none !important;
                                    box-shadow: none !important;
                                    outline: none !important;
                                }
                                .presupuesto-doc .conditions-table,
                                .presupuesto-doc .conditions-table tr,
                                .presupuesto-doc .conditions-table td {
                                    border: none !important;
                                    box-shadow: none !important;
                                    outline: none !important;
                                }
                                .presupuesto-doc .conditions-wrap,
                                .presupuesto-doc .conditions-wrap table,
                                .presupuesto-doc .conditions-wrap tr,
                                .presupuesto-doc .conditions-wrap td {
                                    border: none !important;
                                    box-shadow: none !important;
                                    outline: none !important;
                                }
                                .presupuesto-doc .conditions-right .card,
                                .presupuesto-doc .conditions-right .card table,
                                .presupuesto-doc .conditions-right .card tr,
                                .presupuesto-doc .conditions-right .card td {
                                    box-shadow: none !important;
                                    outline: none !important;
                                }
                                .presupuesto-doc .conditions-right .card {
                                    border-width: 2px !important;
                                }
                                .presupuesto-doc .conditions-right .card table,
                                .presupuesto-doc .conditions-right .card tr,
                                .presupuesto-doc .conditions-right .card td {
                                    border-width: 0 !important;
                                }
                                .presupuesto-doc .totals-line {
                                    display: table;
                                    width: 100%;
                                }
                                .presupuesto-doc .totals-line + .totals-line {
                                    margin-top: 6px;
                                }
                                .presupuesto-doc .totals-label,
                                .presupuesto-doc .totals-value {
                                    display: table-cell;
                                }
                                .presupuesto-doc .totals-label {
                                    font-weight: 700;
                                }
                                .presupuesto-doc .totals-value {
                                    text-align: right;
                                }
                                .presupuesto-doc .header-left-cell {
                                    border-top-left-radius: 8px;
                                    border-bottom-left-radius: 8px;
                                    background-clip: padding-box;
                                }
                                .presupuesto-doc .header-right-cell {
                                    border-top-right-radius: 8px;
                                    border-bottom-right-radius: 8px;
                                    background-clip: padding-box;
                                }
                                .presupuesto-doc .products-head th {
                                    border: 0 !important;
                                    border-bottom: 0 !important;
                                    padding: 6px 6px !important;
                                    line-height: 1.2;
                                    box-sizing: border-box;
                                    color: #ffffff !important;
                                }
                                .presupuesto-doc .products-head th:not(:last-child) {
                                    box-shadow: none !important;
                                    border-right: 0 !important;
                                }
                                .presupuesto-doc .products-head th:first-child {
                                    border-top-left-radius: 9px;
                                }
                                .presupuesto-doc .products-head th:last-child {
                                    border-top-right-radius: 9px;
                                }
                                .presupuesto-doc .products-card {
                                    border-top: 2px solid #8d97a5 !important;
                                    border-radius: 0 !important;
                                }
                                .presupuesto-doc .products-card table {
                                    margin-top: 0;
                                }
                                .presupuesto-doc .conditions-flex {
                                    margin-top: 22mm;
                                    font-size: 10pt;
                                    width: 100%;
                                    display: table;
                                    table-layout: fixed;
                                }
                                .presupuesto-doc .conditions-left,
                                .presupuesto-doc .conditions-right {
                                    display: table-cell;
                                    vertical-align: top;
                                }
                                .presupuesto-doc .conditions-left {
                                    width: 68%;
                                }
                                .presupuesto-doc .conditions-right {
                                    width: 32%;
                                    padding-left: 10px;
                                }
                            </style>

                            <div class="card" style="margin-bottom: 6px;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr>
                                        <td class="header-left-cell" style="width: 28%; padding: 6px 8px; vertical-align: middle; background: transparent; text-align: center;">
                                            <t t-if="o.company_id.logo"><img t-att-src="image_data_uri(o.company_id.logo)" style="max-width: 90px; max-height: 42px; display: block; margin: 0 auto;"/></t>
                                            <t t-else=""><strong><span t-field="o.company_id.name"/></strong></t>
                                        </td>
                                        <td style="width: 14%; text-align: center; vertical-align: middle; font-size: 7pt; background: transparent;">
                                            <div style="display: flex; align-items: center; justify-content: center; min-height: 44px; line-height: 1.1;">Documento<br/>comercial</div>
                                        </td>
                                        <td class="doc-type-box" style="width: 16%; text-align: center; vertical-align: middle; background: transparent;">
                                            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 44px;">
                                                <div style="font-size: 22pt; line-height: 1; font-weight: 700;">P</div>
                                                <div style="font-size: 11pt; line-height: 1.1;">Presupuesto</div>
                                            </div>
                                        </td>
                                        <td class="header-right-cell" style="width: 42%; padding: 5px 8px; vertical-align: top; background: transparent;">
                                            <div style="margin-left: 20%;">
                                                <div style="font-size: 16pt; font-weight: 700; line-height: 1;">PRESUPUESTO</div>
                                                <div style="font-size: 10pt; margin-top: 3px;">Fecha: <span t-field="o.date_order"/></div>
                                                <div style="font-size: 12pt; line-height: 1.1;"><span t-field="o.name"/></div>
                                                <div style="font-size: 8pt; margin-top: 2px;">Validez: <t t-if="o.validity_date"><span t-field="o.validity_date"/></t><t t-else="">Sin fecha de vencimiento</t></div>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <div class="card" style="padding: 7px 8px; margin-bottom: 6px;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr>
                                        <td style="width: 60%; font-size: 10pt; line-height: 1.35; vertical-align: top; padding-left: 1cm;">
                                            <div><span t-field="o.company_id.name"/></div>
                                            <div><span t-field="o.company_id.street"/></div>
                                            <div>
                                                <t t-if="o.company_id.city"><span t-field="o.company_id.city"/></t>
                                                <t t-if="o.company_id.state_id"> <span t-field="o.company_id.state_id"/></t>
                                                <t t-if="o.company_id.zip"> <span t-field="o.company_id.zip"/></t>
                                            </div>
                                            <div><t t-if="o.company_id.country_id"><span t-field="o.company_id.country_id"/></t></div>
                                        </td>
                                        <td style="width: 40%; font-size: 10pt; line-height: 1.35; vertical-align: top;">
                                            <div>
                                                <strong>CUIT:</strong> <span t-esc="o.company_id.afip_cuit or o.company_id.vat or '-'"/>
                                                <span> - </span>
                                                <span t-esc="(o.company_id.l10n_ar_afip_responsibility_type_id and o.company_id.l10n_ar_afip_responsibility_type_id.name) or (o.company_id.partner_id.l10n_ar_afip_responsibility_type_id and o.company_id.partner_id.l10n_ar_afip_responsibility_type_id.name) or '-'"/>
                                            </div>
                                            <div><strong>Email:</strong> <span t-field="o.company_id.email"/></div>
                                            <div><strong>Telefono:</strong> <span t-field="o.company_id.phone"/></div>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <div class="card" style="padding: 7px 8px; margin-bottom: 9px;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr>
                                        <td style="width: 17%; font-size: 10pt; font-weight: 700; vertical-align: top;">Cliente</td>
                                        <td style="width: 33%; font-size: 10pt; line-height: 1.35; vertical-align: top;">
                                            <div><span t-field="o.partner_id"/></div>
                                            <div><span t-field="o.partner_id.street"/></div>
                                            <div>
                                                <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                                <t t-if="o.partner_id.state_id"> <span t-field="o.partner_id.state_id"/></t>
                                                <t t-if="o.partner_id.zip"> <span t-field="o.partner_id.zip"/></t>
                                            </div>
                                            <div><t t-if="o.partner_id.country_id"><span t-field="o.partner_id.country_id"/></t></div>
                                        </td>
                                        <td style="width: 50%; font-size: 10pt; line-height: 1.35; vertical-align: top;">
                                            <div><strong>CUIT:</strong> <span t-field="o.partner_id.vat"/></div>
                                            <div style="margin-top: 5px;"><strong>Email:</strong> <span t-field="o.partner_id.email"/></div>
                                            <div><strong>Telefono:</strong> <span t-field="o.partner_id.phone"/></div>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <div class="card products-card" style="margin-bottom: 6px;">
                                <table style="width: 100%; border-collapse: collapse; table-layout: fixed; font-size: 9pt;">
                                <thead>
                                    <tr class="products-head" t-attf-style="background: {{doc_color or '#8d97a5'}};">
                                        <th style="text-align: left; width: 12%; white-space: nowrap; color: #ffffff;">Codigo</th>
                                        <th style="text-align: left; width: 40%; color: #ffffff;">Descripcion</th>
                                        <th style="text-align: right; width: 10%; white-space: nowrap; color: #ffffff;">Cantidad</th>
                                        <th style="text-align: right; width: 14%; white-space: nowrap; color: #ffffff;">Precio Unitario</th>
                                        <th style="text-align: right; width: 10%; white-space: nowrap; color: #ffffff;">Desc.(%)</th>
                                        <th style="text-align: right; width: 14%; white-space: nowrap; color: #ffffff;">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.order_line" t-as="line">
                                        <tr t-if="not line.display_type">
                                            <td style="padding: 7px 8px 2px 8px; white-space: nowrap;"><span t-field="line.product_id.default_code"/></td>
                                            <td style="padding: 7px 6px 2px 6px; white-space: normal; word-break: break-word;"><span t-field="line.name"/></td>
                                            <td style="padding: 7px 6px 2px 6px; text-align: right; white-space: nowrap;"><span t-field="line.product_uom_qty"/></td>
                                            <td style="padding: 7px 6px 2px 6px; text-align: right; white-space: nowrap;"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                            <td style="padding: 7px 6px 2px 6px; text-align: right; white-space: nowrap;"><span t-field="line.discount"/></td>
                                            <td style="padding: 7px 8px 2px 6px; text-align: right; white-space: nowrap;"><span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                            </div>

                            <div class="conditions-wrap conditions-flex">
                                <div class="conditions-left">
                                    <div><strong>Condiciones de pago:</strong> <span t-field="o.payment_term_id"/></div>
                                    <div style="margin-top: 4px;"><strong>Notas:</strong></div>
                                    <div style="font-size: 9pt;"><span t-field="o.note"/></div>
                                </div>
                                <div class="conditions-right">
                                    <div class="card" style="padding: 0 4px;">
                                        <div class="totals-line" style="padding: 7px 2px;">
                                            <div class="totals-label">Subtotal</div>
                                            <div class="totals-value"><span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></div>
                                        </div>
                                        <div class="totals-line" style="padding: 7px 2px;">
                                            <div class="totals-label">Impuestos</div>
                                            <div class="totals-value"><span t-field="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></div>
                                        </div>
                                        <div class="totals-line" style="padding: 9px 2px; font-size: 15pt;">
                                            <div class="totals-label">Total</div>
                                            <div class="totals-value"><span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div style="margin-top: 8mm; text-align: center; font-size: 8pt; color: #4a4a4a;">
                                Con tecnologia <strong>Odoo</strong> por <strong>AxialPyme</strong>
                            </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
