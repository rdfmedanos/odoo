<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_presupuesto_a4" model="report.paperformat">
        <field name="name">Presupuesto ARCA A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">4</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_sale_order_arca" model="ir.actions.report">
        <field name="name">Presupuesto ARCA (PDF)</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_ar_presupuesto.report_sale_order_arca</field>
        <field name="report_file">l10n_ar_presupuesto.report_sale_order_arca</field>
        <field name="paperformat_id" ref="l10n_ar_presupuesto.paperformat_presupuesto_a4"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Presupuesto_%s' % (object.name or 'draft').replace('/', '_')</field>
    </record>
</odoo>
