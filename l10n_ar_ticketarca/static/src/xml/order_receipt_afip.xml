<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_ar_ticketarca.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <xpath expr="//ReceiptHeader" position="replace"/>

        <xpath expr="//div[hasclass('pt-3')][1]" position="replace">
            <div class="pt-2" style="font-family: monospace; line-height: 1.25; font-size: 13px; text-align: left;">
                <div t-if="order.company_logo_base64" style="text-align: center; margin-bottom: 8px;">
                    <img t-att-src="order.company_logo_base64" style="max-width: 140px; max-height: 80px;" alt="Logo"/>
                </div>
                <div t-if="order.company.vat">CUIT: <t t-out="order.company.vat"/></div>
                <div t-if="order.company.street">
                    Direccion: <t t-out="order.company.street"/>
                    <t t-if="order.company.city" t-out="', ' + order.company.city"/>
                    <t t-if="order.company.state_id and order.company.state_id.code" t-out="', ' + order.company.state_id.code"/>
                </div>
                <div t-if="order.company.phone">Telefono: <t t-out="order.company.phone"/></div>
                <div>Atendido por: <t t-out="order.getCashierName()"/></div>
                <hr/>
                <div style="font-weight: 700;">FACTURA</div>
                <div>NRO DE FACTURA: <t t-out="order.invoiceName or order.name"/></div>
                <div>FECHA: <t t-out="order.date_order.toFormat('dd/MM/yyyy HH:mm:ss')"/></div>
                <hr/>
                <t t-if="order.partner_id">
                    <div>CLIENTE: <t t-out="order.partner_id.name"/></div>
                    <div t-if="order.partner_id.vat">CUIT: <t t-out="order.partner_id.vat"/></div>
                    <div t-if="order.partner_id.street">
                        CALLE: <t t-out="order.partner_id.street"/>
                        <t t-if="order.partner_id.city" t-out="', ' + order.partner_id.city"/>
                    </div>
                    <div t-if="order.partner_id.email">Email: <t t-out="order.partner_id.email"/></div>
                    <div t-if="order.partner_id.phone or order.partner_id.mobile">Tel: <t t-out="order.partner_id.phone or order.partner_id.mobile"/></div>
                </t>
                <hr/>
                <div>REF. INTERNA: <t t-out="order.name"/></div>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt-amount') and hasclass('receipt-total')]" position="before">
            <div style="font-family: monospace; line-height: 1.25; font-size: 13px; text-align: left;">
                <hr/>
                <strong>
                    <div>DESCRIPCION</div>
                    <div>CANT. x PRECIO UNIT.<span class="pos-receipt-right-align">IMPORTE</span></div>
                </strong>
                <hr/>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt-amount') and hasclass('receipt-total')]" position="attributes">
            <attribute name="style">font-family: monospace; font-size: 13px;</attribute>
        </xpath>

        <xpath expr="//div[hasclass('paymentlines') and hasclass('text-start') and hasclass('pt-1')]" position="attributes">
            <attribute name="style">font-family: monospace; font-size: 13px;</attribute>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt-amount') and hasclass('receipt-change')]" position="attributes">
            <attribute name="style">font-family: monospace; font-size: 13px;</attribute>
        </xpath>
    </t>
</templates>
