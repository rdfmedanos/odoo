<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_ar_ticketarca.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
            <t t-set="ticket" t-value="props.data"/>
            <t t-set="afip" t-value="ticket &amp;&amp; ticket.l10n_ar_afip ? ticket.l10n_ar_afip : null"/>
            <t t-set="is_58" t-value="ticket &amp;&amp; ticket.l10n_ar_ticketarca_paper_width == '58'"/>
            <t t-set="afip_font_size" t-value="is_58 ? '11px' : '13px'"/>
            <t t-set="afip_barcode_height" t-value="is_58 ? 60 : 74"/>

            <div t-if="afip &amp;&amp; afip.cae" t-att-style="'margin-top: 12px; border-top: 1px dashed #000; padding-top: 10px; font-size: ' + afip_font_size + '; font-family: monospace; line-height: 1.25; text-align: left;'">
                <div t-if="afip.company_name" t-esc="afip.company_name" style="font-weight: 700;"/>
                <div t-if="afip.company_cuit">CUIT: <span t-esc="afip.company_cuit"/></div>
                <div t-if="afip.company_iibb">Ing. Brutos: <span t-esc="afip.company_iibb"/></div>
                <div t-if="afip.company_start_date">Inicio actividades: <span t-esc="afip.company_start_date"/></div>
                <div t-if="afip.company_iva"><span t-esc="afip.company_iva"/></div>
                <div t-if="afip.company_address">Direccion: <span t-esc="afip.company_address"/></div>
                <div t-if="afip.company_phone">Telefono: <span t-esc="afip.company_phone"/></div>
                <div t-if="ticket.cashier">Usuario: <span t-esc="ticket.cashier"/></div>

                <div style="margin: 6px 0; border-top: 1px dashed #000;"></div>

                <div style="font-weight: 700;">FACTURA <span t-esc="afip.invoice_letter or ''"/></div>
                <div>NRO FACTURA: <span t-esc="afip.invoice_number or ''"/></div>
                <div>FECHA: <span t-esc="ticket.date.localestring"/></div>

                <div style="margin: 6px 0; border-top: 1px dashed #000;"></div>

                <div t-if="afip.partner_name">CLIENTE: <span t-esc="afip.partner_name"/></div>
                <div t-if="afip.partner_vat">CUIT: <span t-esc="afip.partner_vat"/></div>
                <div t-if="afip.partner_iva"><span t-esc="afip.partner_iva"/></div>
                <div t-if="afip.partner_address"><span t-esc="afip.partner_address"/></div>
                <div t-if="afip.partner_email">Email: <span t-esc="afip.partner_email"/></div>
                <div t-if="afip.partner_phone">Tel: <span t-esc="afip.partner_phone"/></div>

                <div style="margin: 6px 0; border-top: 1px dashed #000;"></div>

                <div t-if="afip.order_name">REF INTERNA: <span t-esc="afip.order_name"/></div>

                <div style="margin: 6px 0; border-top: 1px dashed #000;"></div>

                <div style="display: flex; justify-content: space-between;">
                    <span>Subtotal:</span>
                    <span t-esc="afip.amount_untaxed"/>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>IVA:</span>
                    <span t-esc="afip.amount_tax"/>
                </div>
                <div style="display: flex; justify-content: space-between; font-weight: 700; font-size: 1.2em; margin-bottom: 6px;">
                    <span>Total:</span>
                    <span t-esc="afip.amount_total"/>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>Efectivo:</span>
                    <span t-esc="afip.amount_paid"/>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span>Cambio:</span>
                    <span t-esc="afip.amount_change"/>
                </div>

                <div t-if="afip.barcode" style="margin: 2px 0 6px 0; text-align: center;">
                    <img t-att-src="'/report/barcode/?type=Code128&amp;value=' + afip.barcode + '&amp;width=600&amp;height=' + afip_barcode_height" style="width: 100%; object-fit: contain;" alt="Codigo de barras AFIP"/>
                    <div t-esc="afip.barcode" style="font-size: 0.9em; letter-spacing: 0.5px;"/>
                </div>

                <div><strong>CAE:</strong> <span t-esc="afip.cae"/></div>
                <div><strong>Vto. CAE:</strong> <span t-esc="afip.cae_due_date"/></div>
            </div>
        </xpath>
    </t>
</templates>
