<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_ar_ticketarca.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
            <t t-set="ticket" t-value="props.data"/>
            <t t-set="afip" t-value="ticket &amp;&amp; ticket.l10n_ar_afip ? ticket.l10n_ar_afip : null"/>
            <t t-set="is_58" t-value="ticket &amp;&amp; ticket.l10n_ar_ticketarca_paper_width == '58'"/>
            <t t-set="afip_font_size" t-value="is_58 ? '10px' : '12px'"/>
            <t t-set="afip_qr_size" t-value="is_58 ? 96 : 128"/>

            <div t-if="afip &amp;&amp; afip.cae" t-att-style="'margin-top: 12px; border-top: 1px dashed #000; padding-top: 10px; font-size: ' + afip_font_size + '; text-align: center;'">
                <div style="font-weight: 700; margin-bottom: 5px;">Comprobante autorizado ARCA/AFIP</div>
                <div style="margin-bottom: 2px;">
                    <strong>CAE:</strong>
                    <span t-esc="afip.cae"/>
                </div>
                <div style="margin-bottom: 8px;">
                    <strong>Vto. CAE:</strong>
                    <span t-esc="afip.cae_due_date"/>
                </div>

                <div t-if="afip.qr_image" t-att-style="'margin: 0 auto; width: ' + afip_qr_size + 'px;'">
                    <img t-att-src="'data:image/png;base64,' + afip.qr_image" t-att-style="'width: ' + afip_qr_size + 'px; height: ' + afip_qr_size + 'px; display: block; margin: 0 auto;'" alt="QR AFIP"/>
                    <div style="margin-top: 4px;">QR ARCA</div>
                </div>
            </div>
        </xpath>
    </t>
</templates>
